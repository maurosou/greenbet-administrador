# Habilita o reescrevimento de URL
RewriteEngine On

# Cache de recursos estáticos
<IfModule mod_expires.c>
    ExpiresActive On

    # Cache de imagens por 1 ano
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"

    # Cache de CSS e JavaScript por 1 ano
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    # Cache-Control para 1 ano
    <FilesMatch "\.(jpg|jpeg|png|gif|swf|css|js)$">
        Header set Cache-Control "max-age=31536000, public"
    </FilesMatch>
</IfModule>

# Se o arquivo solicitado existir como um arquivo ou diretório, simplesmente o serve.
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -f [OR]
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -d
RewriteRule ^ - [L]

# Se a requisição não corresponder a um arquivo estático, redireciona para index.html
RewriteRule ^ /index.html
